#property copyright "حقوق الطبع والنشر 2025، تداول الذهب الاحترافي"
#property link      "https://www.mql5.com"
#property version   "1.00"
#property description "روبوت تداول الذهب الاحترافي - مستشار خبير متعدد الاستراتيجيات"
#property description "يشمل اتخاذ قرارات مدعومة بالذكاء الاصطناعي، تحليل متعدد الأطر الزمنية،"
#property description "إدارة مخاطر قوية، ومؤشرات فنية متعددة مصممة خصيصاً لتداول الذهب"

#include <Trade\Trade.mqh>
#include <Math\Stat\Math.mqh>

//--- متغيرات الإدخال
input group "=== إعدادات التداول الأساسية ==="
input string          رمز_التداول = "XAUUSD";           // رمز التداول (الذهب مقابل الدولار)
input double          نسبة_المخاطرة = 1.0;              // نسبة المخاطرة لكل صفقة (%)
input double          نسبة_أقصى_انسحاب = 15.0;           // أقصى نسبة انسحاب مسموحة (%)
input int             الرقم_السحري = 12345;             // الرقم السحري للمستشار
input bool            تمكين_السكالبينج = true;          // تمكين استراتيجية السكالبينج
input bool            تمكين_التداول_المتأرجح = true;     // تمكين استراتيجية التداول المتأرجح

input group "=== إدارة المخاطر المتقدمة ==="
input int             أقصى_مراكز = 3;                   // أقصى عدد مراكز متزامنة
input double          وقف_خسارة_ثابت = 50.0;           // وقف الخسارة الثابت (نقطة)
input double          جني_أرباح_ثابت = 100.0;          // جني الأرباح الثابت (نقطة)
input bool            استخدام_وقف_متحرك = true;        // استخدام وقف الخسارة المتحرك
input double          خطوة_الوقف_المتحرك = 20.0;       // خطوة الوقف المتحرك (نقطة)

input group "=== إعدادات المؤشرات الفنية ==="
input int             فترة_الايما_السريع = 21;          // فترة المتوسط المتحرك الأسي السريع
input int             فترة_الايما_البطيء = 50;          // فترة المتوسط المتحرك الأسي البطيء
input int             فترة_الآر_اس_آي = 14;            // فترة مؤشر القوة النسبية
input int             فترة_البولنجر = 20;              // فترة خطوط البولنجر
input double          انحراف_البولنجر = 2.0;           // انحراف خطوط البولنجر
input int             فترة_الحجم_المتوسط = 20;          // فترة متوسط الحجم

input group "=== فلترة الوقت والجلسات ==="
input bool            تفعيل_فلتر_الوقت = true;         // تفعيل فلتر الوقت
input int             ساعة_بداية_التداول = 8;          // ساعة بداية التداول (GMT)
input int             ساعة_نهاية_التداول = 22;         // ساعة نهاية التداول (GMT)
input bool            تجنب_الأخبار = true;             // تجنب التداول أثناء الأخبار المهمة
input int             دقائق_تجنب_الأخبار = 30;         // دقائق تجنب التداول قبل/بعد الأخبار

input group "=== إعدادات الذكاء الاصطناعي ==="
input double          حساسية_الاتجاه = 0.7;            // حساسية كشف الاتجاه (0.1-1.0)
input double          عتبة_التقلبات = 0.5;             // عتبة التقلبات للدخول (0.1-1.0)
input double          قوة_الإشارة_المطلوبة = 0.6;       // قوة الإشارة المطلوبة للدخول (0.1-1.0)

//--- متغيرات عامة
CTrade            التداول;
int               مؤشر_الايما_السريع;
int               مؤشر_الايما_البطيء;
int               مؤشر_الآر_اس_آي;
int               مؤشر_البولنجر;
int               مؤشر_الحجم;
int               مؤشر_اي_تي_آر;
datetime          آخر_وقت_شمعة;
double            رصيد_البداية;
bool              حالة_الطوارئ = false;

//--- هياكل البيانات للذكاء الاصطناعي
struct بيانات_السوق
{
   double قوة_الاتجاه;
   double مؤشر_التقلبات;
   double معنويات_السوق;
   double مستوى_الحجم;
   bool   في_اتجاه_صاعد;
   bool   في_اتجاه_هابط;
   bool   في_نطاق_جانبي;
};

struct إشارة_تداول
{
   int    نوع_الإشارة;        // 1=شراء، -1=بيع، 0=لا إشارة
   double قوة_الإشارة;
   string سبب_الإشارة;
   double مستوى_الدخول;
   double مستوى_وقف_الخسارة;
   double مستوى_جني_الأرباح;
};

//+------------------------------------------------------------------+
//| دالة التهيئة                                                      |
//+------------------------------------------------------------------+
int OnInit()
{
   Print("بدء تشغيل روبوت تداول الذهب الاحترافي...");
   
   //--- فحص الرمز
   if(Symbol() != رمز_التداول)
   {
      Alert("تحذير: الرمز الحالي (" + Symbol() + ") لا يتطابق مع الرمز المحدد (" + رمز_التداول + ")");
   }
   
   //--- تهيئة المؤشرات
   if(!تهيئة_المؤشرات())
   {
      Print("خطأ في تهيئة المؤشرات");
      return INIT_FAILED;
   }
   
   //--- تهيئة إعدادات التداول
   التداول.SetExpertMagicNumber(الرقم_السحري);
   التداول.SetDeviationInPoints(10);
   التداول.SetTypeFilling(ORDER_FILLING_IOC);
   
   //--- حفظ الرصيد الأولي
   رصيد_البداية = AccountInfoDouble(ACCOUNT_BALANCE);
   آخر_وقت_شمعة = 0;
   
   Print("تم تشغيل روبوت تداول الذهب بنجاح!");
   Print("الرمز: ", رمز_التداول);
   Print("نسبة المخاطرة: ", نسبة_المخاطرة, "%");
   Print("أقصى انسحاب: ", نسبة_أقصى_انسحاب, "%");
   
   return INIT_SUCCEEDED;
}

//+------------------------------------------------------------------+
//| دالة إلغاء التهيئة                                                |
//+------------------------------------------------------------------+
void OnDeinit(const int reason)
{
   Print("إيقاف روبوت تداول الذهب...");
   
   //--- تحرير المؤشرات
   if(مؤشر_الايما_السريع != INVALID_HANDLE) IndicatorRelease(مؤشر_الايما_السريع);
   if(مؤشر_الايما_البطيء != INVALID_HANDLE) IndicatorRelease(مؤشر_الايما_البطيء);
   if(مؤشر_الآر_اس_آي != INVALID_HANDLE) IndicatorRelease(مؤشر_الآر_اس_آی);
   if(مؤشر_البولنجر != INVALID_HANDLE) IndicatorRelease(مؤشر_البولنجر);
   if(مؤشر_الحجم != INVALID_HANDLE) IndicatorRelease(مؤشر_الحجم);
   if(مؤشر_اي_تي_آر != INVALID_HANDLE) IndicatorRelease(مؤشر_اي_تي_آر);
   
   Print("تم إيقاف الروبوت بنجاح. سبب الإيقاف: ", reason);
}

//+------------------------------------------------------------------+
//| دالة التجربة (Tick)                                              |
//+------------------------------------------------------------------+
void OnTick()
{
   //--- فحص شمعة جديدة
   if(!شمعة_جديدة()) return;
   
   //--- فحص حالة الطوارئ
   if(فحص_حالة_الطوارئ())
   {
      if(!حالة_الطوارئ)
      {
         Print("تحذير: تم تفعيل حالة الطوارئ - إيقاف التداول مؤقتاً");
         حالة_الطوارئ = true;
      }
      return;
   }
   else
   {
      if(حالة_الطوارئ)
      {
         Print("تم إلغاء حالة الطوارئ - استئناف التداول");
         حالة_الطوارئ = false;
      }
   }
   
   //--- تحديث إدارة المراكز
   إدارة_المراكز_المفتوحة();
   
   //--- فحص فلاتر التداول
   if(!فحص_فلاتر_التداول()) return;
   
   //--- تحليل السوق والحصول على إشارة
   إشارة_تداول إشارة = تحليل_السوق_والحصول_على_إشارة();
   
   //--- تنفيذ الإشارة
   if(إشارة.نوع_الإشارة != 0 && إشارة.قوة_الإشارة >= قوة_الإشارة_المطلوبة)
   {
      تنفيذ_إشارة_التداول(إشارة);
   }
}

//+------------------------------------------------------------------+
//| تهيئة المؤشرات الفنية                                             |
//+------------------------------------------------------------------+
bool تهيئة_المؤشرات()
{
   //--- تهيئة المتوسطات المتحركة الأسية
   مؤشر_الايما_السريع = iMA(رمز_التداول, PERIOD_CURRENT, فترة_الايما_السريع, 0, MODE_EMA, PRICE_CLOSE);
   if(مؤشر_الايما_السريع == INVALID_HANDLE)
   {
      Print("خطأ في إنشاء مؤشر EMA السريع");
      return false;
   }
   
   مؤشر_الايما_البطيء = iMA(رمز_التداول, PERIOD_CURRENT, فترة_الايما_البطيء, 0, MODE_EMA, PRICE_CLOSE);
   if(مؤشر_الايما_البطيء == INVALID_HANDLE)
   {
      Print("خطأ في إنشاء مؤشر EMA البطيء");
      return false;
   }
   
   //--- تهيئة مؤشر القوة النسبية
   مؤشر_الآر_اس_آی = iRSI(رمز_التداول, PERIOD_CURRENT, فترة_الآر_اس_آی, PRICE_CLOSE);
   if(مؤشر_الآر_اس_آی == INVALID_HANDLE)
   {
      Print("خطأ في إنشاء مؤشر RSI");
      return false;
   }
   
   //--- تهيئة خطوط البولنجر
   مؤشر_البولنجر = iBands(رمز_التداول, PERIOD_CURRENT, فترة_البولنجر, 0, انحراف_البولنجر, PRICE_CLOSE);
   if(مؤشر_البولنجر == INVALID_HANDLE)
   {
      Print("خطأ في إنشاء مؤشر خطوط البولنجر");
      return false;
   }
   
   //--- تهيئة مؤشر الحجم
   مؤشر_الحجم = iVolumes(رمز_التداول, PERIOD_CURRENT, VOLUME_TICK);
   if(مؤشر_الحجم == INVALID_HANDLE)
   {
      Print("خطأ في إنشاء مؤشر الحجم");
      return false;
   }
   
   //--- تهيئة مؤشر ATR
   مؤشر_اي_تي_آر = iATR(رمز_التداول, PERIOD_CURRENT, 14);
   if(مؤشر_اي_تي_آر == INVALID_HANDLE)
   {
      Print("خطأ في إنشاء مؤشر ATR");
      return false;
   }
   
   return true;
}

//+------------------------------------------------------------------+
//| فحص شمعة جديدة                                                   |
//+------------------------------------------------------------------+
bool شمعة_جديدة()
{
   datetime وقت_حالي = iTime(رمز_التداول, PERIOD_CURRENT, 0);
   if(وقت_حالي != آخر_وقت_شمعة)
   {
      آخر_وقت_شمعة = وقت_حالي;
      return true;
   }
   return false;
}

//+------------------------------------------------------------------+
//| فحص حالة الطوارئ                                                 |
//+------------------------------------------------------------------+
bool فحص_حالة_الطوارئ()
{
   //--- فحص الانسحاب
   double الرصيد_الحالي = AccountInfoDouble(ACCOUNT_BALANCE);
   double نسبة_الانسحاب = ((رصيد_البداية - الرصيد_الحالي) / رصيد_البداية) * 100.0;
   
   if(نسبة_الانسحاب >= نسبة_أقصى_انسحاب)
   {
      return true;
   }
   
   //--- فحص عدد المراكز
   if(عدد_المراكز_المفتوحة() >= أقصى_مراكز * 2)
   {
      return true;
   }
   
   //--- فحص الهامش
   double مستوى_الهامش = AccountInfoDouble(ACCOUNT_MARGIN_LEVEL);
   if(مستوى_الهامش > 0 && مستوى_الهامش < 200.0)
   {
      return true;
   }
   
   return false;
}

//+------------------------------------------------------------------+
//| فحص فلاتر التداول                                                |
//+------------------------------------------------------------------+
bool فحص_فلاتر_التداول()
{
   //--- فلتر الوقت
   if(تفعيل_فلتر_الوقت)
   {
      MqlDateTime وقت_dt;
      TimeToStruct(TimeCurrent(), وقت_dt);
      
      if(وقت_dt.hour < ساعة_بداية_التداول || وقت_dt.hour >= ساعة_نهاية_التداول)
      {
         return false;
      }
   }
   
   //--- فلتر عدد المراكز
   if(عدد_المراكز_المفتوحة() >= أقصى_مراكز)
   {
      return false;
   }
   
   //--- فلتر السبريد
   double السبريد = SymbolInfoDouble(رمز_التداول, SYMBOL_SPREAD) * SymbolInfoDouble(رمز_التداول, SYMBOL_POINT);
   double متوسط_السبريد = السبريد * 2.0; // حد أقصى مقبول
   
   if(السبريد > متوسط_السبريد)
   {
      return false;
   }
   
   return true;
}

//+------------------------------------------------------------------+
//| تحليل السوق والحصول على إشارة تداول                               |
//+------------------------------------------------------------------+
إشارة_تداول تحليل_السوق_والحصول_على_إشارة()
{
   إشارة_تداول إشارة = {0, 0.0, "", 0.0, 0.0, 0.0};
   
   //--- تحليل بيانات السوق
   بيانات_السوق بيانات = تحليل_بيانات_السوق();
   
   //--- استراتيجية السكالبينج (الإطار الزمني الحالي)
   if(تمكين_السكالبينج && Period() <= PERIOD_M5)
   {
      إشارة_تداول إشارة_سكالبينج = استراتيجية_السكالبينج(بيانات);
      if(إشارة_سكالبينج.نوع_الإشارة != 0)
      {
         إشارة = إشارة_سكالبينج;
         إشارة.سبب_الإشارة = "سكالبينج: " + إشارة.سبب_الإشارة;
      }
   }
   
   //--- استراتيجية التداول المتأرجح (الأطر الزمنية الأكبر)
   if(تمكين_التداول_المتأرجح && إشارة.نوع_الإشارة == 0)
   {
      إشارة_تداول إشارة_متأرجحة = استراتيجية_التداول_المتأرجح(بيانات);
      if(إشارة_متأرجحة.نوع_الإشارة != 0)
      {
         إشارة = إشارة_متأرجحة;
         إشارة.سبب_الإشارة = "تداول متأرجح: " + إشارة.سبب_الإشارة;
      }
   }
   
   return إشارة;
}

//+------------------------------------------------------------------+
//| تحليل بيانات السوق (منطق الذكاء الاصطناعي)                         |
//+------------------------------------------------------------------+
بيانات_السوق تحليل_بيانات_السوق()
{
   بيانات_السوق بيانات;
   
   //--- الحصول على قيم المؤشرات
   double ايما_سريع[], ايما_بطيء[], rsi[], bb_upper[], bb_lower[], bb_middle[];
   long حجم[];
   double atr[];
   
   //--- نسخ البيانات
   CopyBuffer(مؤشر_الايما_السريع, 0, 0, 3, ايما_سريع);
   CopyBuffer(مؤشر_الايما_البطيء, 0, 0, 3, ايما_بطيء);
   CopyBuffer(مؤشر_الآر_اس_آی, 0, 0, 3, rsi);
   CopyBuffer(مؤشر_البولنجر, 0, 0, 3, bb_upper);
   CopyBuffer(مؤشر_البولنجر, 1, 0, 3, bb_middle);
   CopyBuffer(مؤشر_البولنجر, 2, 0, 3, bb_lower);
   CopyBuffer(مؤشر_الحجم, 0, 0, فترة_الحجم_المتوسط, حجم);
   CopyBuffer(مؤشر_اي_تي_آر, 0, 0, 3, atr);
   
   double السعر_الحالي = SymbolInfoDouble(رمز_التداول, SYMBOL_BID);
   
   //--- حساب قوة الاتجاه (AI Logic)
   double فرق_الايما = MathAbs(ايما_سريع[0] - ايما_بطيء[0]);
   double مدى_السعر = SymbolInfoDouble(رمز_التداول, SYMBOL_BID) - SymbolInfoDouble(رمز_التداول, SYMBOL_ASK);
   بيانات.قوة_الاتجاه = فرق_الايما / (atr[0] + 0.0001); // تجنب القسمة على صفر
   بيانات.قوة_الاتجاه = MathMin(بيانات.قوة_الاتجاه, 1.0);
   
   //--- حساب مؤشر التقلبات
   بيانات.مؤشر_التقلبات = atr[0] / السعر_الحالي;
   بيانات.مؤشر_التقلبات = MathMin(بيانات.مؤشر_التقلبات * 100, 1.0);
   
   //--- حساب معنويات السوق
   double موقع_rsi = (rsi[0] - 50.0) / 50.0; // تطبيع من -1 إلى 1
   double موقع_bb = 0;
   if(bb_upper[0] != bb_lower[0])
      موقع_bb = (السعر_الحالي - bb_lower[0]) / (bb_upper[0] - bb_lower[0]) * 2.0 - 1.0;
   
   بيانات.معنويات_السوق = (موقع_rsi + موقع_bb) / 2.0;
   
   //--- حساب مستوى الحجم
   double متوسط_الحجم = 0;
   for(int i = 0; i < فترة_الحجم_المتوسط; i++)
      متوسط_الحجم += حجم[i];
   متوسط_الحجم /= فترة_الحجم_المتوسط;
   
   بيانات.مستوى_الحجم = (حجم[0] > متوسط_الحجم * 1.5) ? 1.0 : 0.5;
   
   //--- تحديد حالة السوق
   بيانات.في_اتجاه_صاعد = (ايما_سريع[0] > ايما_بطيء[0]) && (بيانات.قوة_الاتجاه > حساسية_الاتجاه);
   بيانات.في_اتجاه_هابط = (ايما_سريع[0] < ايما_بطيء[0]) && (بيانات.قوة_الاتجاه > حساسية_الاتجاه);
   بيانات.في_نطاق_جانبي = !بيانات.في_اتجاه_صاعد && !بيانات.في_اتجاه_هابط;
   
   return بيانات;
}

//+------------------------------------------------------------------+
//| استراتيجية السكالبينج                                            |
//+------------------------------------------------------------------+
إشارة_تداول استراتيجية_السكالبينج(بيانات_السوق &بيانات)
{
   إشارة_تداول إشارة = {0, 0.0, "", 0.0, 0.0, 0.0};
   
   //--- شروط الدخول للسكالبينج
   if(بيانات.مؤشر_التقلبات < عتبة_التقلبات) return إشارة; // تقلبات منخفضة
   if(بيانات.مستوى_الحجم < 0.8) return إشارة; // حجم منخفض
   
   double السعر_الحالي = SymbolInfoDouble(رمز_التداول, SYMBOL_BID);
   double النقطة = SymbolInfoDouble(رمز_التداول, SYMBOL_POINT);
   double atr[];
   CopyBuffer(مؤشر_اي_تي_آر, 0, 0, 1, atr);
   
   //--- إشارة شراء
   if(بيانات.في_اتجاه_صاعد && بيانات.معنويات_السوق > -0.3)
   {
      إشارة.نوع_الإشارة = 1;
      إشارة.قوة_الإشارة = بيانات.قوة_الاتجاه * بيانات.مستوى_الحجم;
      إشارة.سبب_الإشارة = "اتجاه صاعد + حجم عالي";
      إشارة.مستوى_الدخول = SymbolInfoDouble(رمز_التداول, SYMBOL_ASK);
      إشارة.مستوى_وقف_الخسارة = إشارة.مستوى_الدخول - (atr[0] * 1.5);
      إشارة.مستوى_جني_الأرباح = إشارة.مستوى_الدخول + (atr[0] * 2.0);
   }
   //--- إشارة بيع
   else if(بيانات.في_اتجاه_هابط && بيانات.معنويات_السوق < 0.3)
   {
      إشارة.نوع_الإشارة = -1;
      إشارة.قوة_الإشارة = بيانات.قوة_الاتجاه * بيانات.مستوى_الحجم;
      إشارة.سبب_الإشارة = "اتجاه هابط + حجم عالي";
      إشارة.مستوى_الدخول = SymbolInfoDouble(رمز_التداول, SYMBOL_BID);
      إشارة.مستوى_وقف_الخسارة = إشارة.مستوى_الدخول + (atr[0] * 1.5);
      إشارة.مستوى_جني_الأرباح = إشارة.مستوى_الدخول - (atr[0] * 2.0);
   }
   
   return إشارة;
}

//+------------------------------------------------------------------+
//| استراتيجية التداول المتأرجح                                        |
//+------------------------------------------------------------------+
إشارة_تداول استراتيجية_التداول_المتأرجح(بيانات_السوق &بيانات)
{
   إشارة_تداول إشارة = {0, 0.0, "", 0.0, 0.0, 0.0};
   
   double rsi[];
   double bb_upper[], bb_lower[];
   CopyBuffer(مؤشر_الآر_اس_آی, 0, 0, 3, rsi);
   CopyBuffer(مؤشر_البولنجر, 0, 0, 1, bb_upper);
   CopyBuffer(مؤشر_البولنجر, 2, 0, 1, bb_lower);
   
   double السعر_الحالي = SymbolInfoDouble(رمز_التداول, SYMBOL_BID);
   double atr[];
   CopyBuffer(مؤشر_اي_تي_آر, 0, 0, 1, atr);
   
   //--- إشارة شراء (تشبع في البيع + اتجاه صاعد)
   if(rsi[0] < 30 && بيانات.في_اتجاه_صاعد && السعر_الحالي <= bb_lower[0])
   {
      إشارة.نوع_الإشارة = 1;
      إشارة.قوة_الإشارة = (1.0 - rsi[0]/100.0) * بيانات.قوة_الاتجاه;
      إشارة.سبب_الإشارة = "تشبع في البيع + اتجاه صاعد";
      إشارة.مستوى_الدخول = SymbolInfoDouble(رمز_التداول, SYMBOL_ASK);
      إشارة.مستوى_وقف_الخسارة = إشارة.مستوى_الدخول - (atr[0] * 2.5);
      إشارة.مستوى_جني_الأرباح = إشارة.مستوى_الدخول + (atr[0] * 4.0);
   }
   //--- إشارة بيع (تشبع في الشراء + اتجاه هابط)
   else if(rsi[0] > 70 && بيانات.في_اتجاه_هابط && السعر_الحالي >= bb_upper[0])
   {
      إشارة.نوع_الإشارة = -1;
      إشارة.قوة_الإشارة = (rsi[0]/100.0) * بيانات.قوة_الاتجاه;
      إشارة.سبب_الإشارة = "تشبع في الشراء + اتجاه هابط";
      إشارة.مستوى_الدخول = SymbolInfoDouble(رمز_التداول, SYMBOL_BID);
      إشارة.مستوى_وقف_الخسارة = إشارة.مستوى_الدخول + (atr[0] * 2.5);
      إشارة.مستوى_جني_الأرباح = إشارة.مستوى_الدخول - (atr[0] * 4.0);
   }
   
   return إشارة;
}

//+------------------------------------------------------------------+
//| تنفيذ إشارة التداول                                               |
//+------------------------------------------------------------------+
void تنفيذ_إشارة_التداول(إشارة_تداول &إشارة)
{
   //--- حساب حجم المركز
   double حجم_المركز = حساب_حجم_المركز();
   
   if(حجم_المركز <= 0)
   {
      Print("لا يمكن حساب حجم المركز");
      return;
   }
   
   //--- تنفيذ الصفقة
   bool نتيجة = false;
   
   if(إشارة.نوع_الإشارة == 1) // شراء
   {
      نتيجة = التداول.Buy(حجم_المركز, رمز_التداول, إشارة.مستوى_الدخول, 
                          إشارة.مستوى_وقف_الخسارة, إشارة.مستوى_جني_الأرباح, 
                          "شراء: " + إشارة.سبب_الإشارة);
   }
   else if(إشارة.نوع_الإشارة == -1) // بيع
   {
      نتيجة = التداول.Sell(حجم_المركز, رمز_التداول, إشارة.مستوى_الدخول,
                           إشارة.مستوى_وقف_الخسارة, إشارة.مستوى_جني_الأرباح,
                           "بيع: " + إشارة.سبب_الإشارة);
   }
   
   if(نتيجة)
   {
      Print("تم تنفيذ الصفقة بنجاح: ", إشارة.سبب_الإشارة);
      Print("حجم المركز: ", حجم_المركز);
      Print("قوة الإشارة: ", DoubleToString(إشارة.قوة_الإشارة, 3));
   }
   else
   {
      Print("فشل في تنفيذ الصفقة: ", التداول.ResultRetcode());
   }
}

//+------------------------------------------------------------------+
//| حساب حجم المركز                                                  |
//+------------------------------------------------------------------+
double حساب_حجم_المركز()
{
   double الرصيد = AccountInfoDouble(ACCOUNT_BALANCE);
   double مبلغ_المخاطرة = الرصيد * (نسبة_المخاطرة / 100.0);
   
   double atr[];
   CopyBuffer(مؤشر_اي_تي_آر, 0, 0, 1, atr);
   
   double وقف_الخسارة_نقاط = MathMax(وقف_خسارة_ثابت, atr[0] / SymbolInfoDouble(رمز_التداول, SYMBOL_POINT));
   double قيمة_النقطة = SymbolInfoDouble(رمز_التداول, SYMBOL_TRADE_TICK_VALUE);
   
   double حجم_المركز = مبلغ_المخاطرة / (وقف_الخسارة_نقاط * قيمة_النقطة);
   
   //--- تطبيق حدود الحجم
   double الحد_الأدنى = SymbolInfoDouble(رمز_التداول, SYMBOL_VOLUME_MIN);
   double الحد_الأقصى = SymbolInfoDouble(رمز_التداول, SYMBOL_VOLUME_MAX);
   double خطوة_الحجم = SymbolInfoDouble(رمز_التداول, SYMBOL_VOLUME_STEP);
   
   حجم_المركز = MathMax(حجم_المركز, الحد_الأدنى);
   حجم_المركز = MathMin(حجم_المركز, الحد_الأقصى);
   حجم_المركز = MathFloor(حجم_المركز / خطوة_الحجم) * خطوة_الحجم;
   
   return حجم_المركز;
}

//+------------------------------------------------------------------+
//| إدارة المراكز المفتوحة                                            |
//+------------------------------------------------------------------+
void إدارة_المراكز_المفتوحة()
{
   for(int i = PositionsTotal() - 1; i >= 0; i--)
   {
      if(PositionGetTicket(i) > 0)
      {
         if(PositionGetString(POSITION_SYMBOL) == رمز_التداول && 
            PositionGetInteger(POSITION_MAGIC) == الرقم_السحري)
         {
            //--- تطبيق وقف الخسارة المتحرك
            if(استخدام_وقف_متحرك)
            {
               تطبيق_وقف_متحرك(PositionGetTicket(i));
            }
            
            //--- فحص إغلاق جزئي
            فحص_إغلاق_جزئي(PositionGetTicket(i));
         }
      }
   }
}

//+------------------------------------------------------------------+
//| تطبيق وقف الخسارة المتحرك                                          |
//+------------------------------------------------------------------+
void تطبيق_وقف_متحرك(ulong تذكرة)
{
   if(!PositionSelectByTicket(تذكرة)) return;
   
   double السعر_الحالي = (PositionGetInteger(POSITION_TYPE) == POSITION_TYPE_BUY) ? 
                         SymbolInfoDouble(رمز_التداول, SYMBOL_BID) : 
                         SymbolInfoDouble(رمز_التداول, SYMBOL_ASK);
   
   double سعر_الفتح = PositionGetDouble(POSITION_PRICE_OPEN);
   double وقف_الخسارة_الحالي = PositionGetDouble(POSITION_SL);
   double النقطة = SymbolInfoDouble(رمز_التداول, SYMBOL_POINT);
   
   double وقف_خسارة_جديد = 0;
   
   if(PositionGetInteger(POSITION_TYPE) == POSITION_TYPE_BUY)
   {
      وقف_خسارة_جديد = السعر_الحالي - (خطوة_الوقف_المتحرك * النقطة);
      if(وقف_خسارة_جديد > وقف_الخسارة_الحالي && وقف_خسارة_جديد < السعر_الحالي)
      {
         التداول.PositionModify(تذكرة, وقف_خسارة_جديد, PositionGetDouble(POSITION_TP));
      }
   }
   else
   {
      وقف_خسارة_جديد = السعر_الحالي + (خطوة_الوقف_المتحرك * النقطة);
      if((وقف_الخسارة_الحالي == 0 || وقف_خسارة_جديد < وقف_الخسارة_الحالي) && 
         وقف_خسارة_جديد > السعر_الحالي)
      {
         التداول.PositionModify(تذكرة, وقف_خسارة_جديد, PositionGetDouble(POSITION_TP));
      }
   }
}

//+------------------------------------------------------------------+
//| فحص الإغلاق الجزئي                                               |
//+------------------------------------------------------------------+
void فحص_إغلاق_جزئي(ulong تذكرة)
{
   if(!PositionSelectByTicket(تذكرة)) return;
   
   double الربح_الحالي = PositionGetDouble(POSITION_PROFIT);
   double حجم_المركز = PositionGetDouble(POSITION_VOLUME);
   
   //--- إغلاق 50% عند ربح 2% من الرصيد
   double هدف_الربح = AccountInfoDouble(ACCOUNT_BALANCE) * 0.02;
   
   if(الربح_الحالي >= هدف_الربح && حجم_المركز > SymbolInfoDouble(رمز_التداول, SYMBOL_VOLUME_MIN))
   {
      double حجم_الإغلاق = حجم_المركز * 0.5;
      حجم_الإغلاق = MathMax(حجم_الإغلاق, SymbolInfoDouble(رمز_التداول, SYMBOL_VOLUME_MIN));
      
      if(PositionGetInteger(POSITION_TYPE) == POSITION_TYPE_BUY)
      {
         التداول.Sell(حجم_الإغلاق, رمز_التداول, 0, 0, 0, "إغلاق جزئي - ربح");
      }
      else
      {
         التداول.Buy(حجم_الإغلاق, رمز_التداول, 0, 0, 0, "إغلاق جزئي - ربح");
      }
   }
}

//+------------------------------------------------------------------+
//| عدد المراكز المفتوحة                                              |
//+------------------------------------------------------------------+
int عدد_المراكز_المفتوحة()
{
   int عدد = 0;
   for(int i = 0; i < PositionsTotal(); i++)
   {
      if(PositionGetTicket(i) > 0)
      {
         if(PositionGetString(POSITION_SYMBOL) == رمز_التداول && 
            PositionGetInteger(POSITION_MAGIC) == الرقم_السحري)
         {
            عدد++;
         }
      }
   }
   return عدد;
}